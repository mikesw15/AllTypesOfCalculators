{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's ID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "A favorited calculator",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "calculatorId": { "type": "string" },
        "addedAt": { "type": "timestamp" }
      },
      "required": ["userId", "calculatorId", "addedAt"]
    },
    "History": {
      "title": "History",
      "description": "A history entry of a calculation",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "calculatorId": { "type": "string" },
        "inputs": { "type": "string", "description": "JSON stringified inputs" },
        "results": { "type": "string", "description": "JSON stringified results" },
        "calculatedAt": { "type": "timestamp" }
      },
      "required": ["userId", "calculatorId", "calculatedAt"]
    },
    "SavedPassword": {
      "title": "Saved Password",
      "description": "A saved generated password",
      "type": "object",
      "properties": {
        "password": { "type": "string" },
        "label": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["password", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A user's review and rating for a calculator",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userDisplayName": { "type": "string" },
        "calculatorId": { "type": "string" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["userId", "calculatorId", "rating", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "User reviews for calculators"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/users/{userId}/favorites/{favoriteId}": {
      "schema": { "$ref": "#/entities/Favorite" },
      "description": "User's favorite calculators"
    },
    "/users/{userId}/history/{historyId}": {
      "schema": { "$ref": "#/entities/History" },
      "description": "User's calculation history"
    },
    "/users/{userId}/saved_passwords/{passwordId}": {
      "schema": { "$ref": "#/entities/SavedPassword" },
      "description": "User's saved passwords"
    }
  }
}
